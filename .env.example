# Flask
SECRET_KEY=change-me-to-a-random-string-in-production
DATABASE_URL=sqlite:///eventalpha.db

# AI Assistant widget (set false to disable the floating assistant)
ENABLE_AI_ASSISTANT=true

# Floating assistant widget (FAB + draggable window). false = hide widget only,
# homepage inline chat stays functional. Requires ENABLE_AI_ASSISTANT=true.
ENABLE_ASSISTANT_WIDGET=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# LLM - DeepSeek (primary)
# 备选: LLM_PROVIDER=qwen (通义千问) / zhipu (智谱) / ollama (本地)
LLM_PROVIDER=deepseek
LLM_API_KEY=sk-your-api-key-here
LLM_API_BASE=https://api.deepseek.com/v1
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=4096
LLM_MAX_CONCURRENCY=5
LLM_RATE_LIMIT_RPM=60
LLM_RETRY_COUNT=3

# Embedding (local text2vec, no API key needed)
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5

# News sources (comma-separated connector names: cls/ak_cctv/ak_futures)
NEWS_SOURCES=cls,ak_cctv,ak_futures

# Market data
AKSHARE_ENABLED=true
TUSHARE_TOKEN=

# Pagination
EVENTS_PER_PAGE=20

# Notification (optional)
WECHAT_WEBHOOK_URL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
